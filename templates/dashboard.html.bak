{% extends "base.html" %}
 
{% block content %}
 
<div class="dashboard-container">
 
    <h1>Welcome {{ user }}</h1>
 
    <div class="journal-card">
        <h2>How are you feeling today?</h2>
 
        <form method="POST">
            <textarea
                name="entry"
                placeholder="Write your thoughts..."
                rows="6"
                required></textarea>
 
            <button type="submit">
                Analyze Mood
            </button>
        </form>
    </div>
 
    {% if latest_mood %}
    <div class="result-card">
        <h2>Mood Analysis</h2>
        <p><strong>Detected Mood:</strong> {{ latest_mood }}</p>
 
        <h3>Motivational Message</h3>
        <p>{{ latest_message }}</p>
 
        <h3>Insights</h3>
        <p>{{ latest_insights }}</p>
 
        <h3>Recommendations</h3>
        <p style="white-space: pre-line;">{{ latest_recommendations }}</p>
    </div>
    {% endif %}
 
    <!-- ════════════════════════════════════════════════════════════════
         MOOD TREND PANEL  (new — calls /mood_compare)
         Shows up on every dashboard load via fetch(); the user can also
         manually refresh it with the "Refresh Trend" button.
    ═══════════════════════════════════════════════════════════════════ -->
    <div class="result-card" id="mood-trend-panel">
        <h2>🔄 Your Mood Trend</h2>
 
        <!-- Loading state shown while fetch is in flight -->
        <div id="trend-loading">
            <p style="color:#888;">Loading your mood trend…</p>
        </div>
 
        <!-- Populated by loadMoodTrend() -->
        <div id="trend-content" style="display:none;">
            <p id="trend-summary"></p>
 
            <!-- Mini mood history timeline -->
            <div id="trend-history" style="display:flex;gap:8px;flex-wrap:wrap;margin:10px 0;"></div>
 
            <h3>AI Suggestions</h3>
            <p id="trend-suggestions" style="white-space:pre-line;"></p>
 
            <button type="button" onclick="loadMoodTrend()" style="margin-top:8px;">
                ↺ Refresh Trend
            </button>
        </div>
 
        <div id="trend-error" style="display:none;color:#c00;">
            <p>Could not load trend data. Please try again.</p>
        </div>
    </div>
    <!-- ════════════════════════════════════════════════════════════════
         END MOOD TREND PANEL
    ═══════════════════════════════════════════════════════════════════ -->
 
    <!-- ════════════════════════════════════════════════════════════════
         COACH PANEL  (new — calls /coach/proactive and /coach/message)
         The coach opens automatically after a new journal entry is
         submitted (proactive message).  The user can then keep chatting.
    ═══════════════════════════════════════════════════════════════════ -->
    <div class="result-card" id="coach-panel">
        <h2>🧠 Your Wellness Coach</h2>
 
        <!-- Chat message window -->
        <div id="coach-messages"
             style="max-height:320px;overflow-y:auto;display:flex;
                    flex-direction:column;gap:10px;margin-bottom:14px;
                    padding:10px;background:#f9f9f9;border-radius:8px;
                    border:1px solid #e0e0e0;">
 
            <!-- Seeded with proactive message when latest_mood is present,
                 otherwise shows a static welcome note -->
            {% if latest_mood %}
            <div class="coach-msg coach-msg--coach">
                <span class="coach-msg__label">Coach</span>
                <p class="coach-msg__text" id="proactive-msg-text">
                    Loading your personalised coaching message…
                </p>
            </div>
            {% else %}
            <div class="coach-msg coach-msg--coach">
                <span class="coach-msg__label">Coach</span>
                <p class="coach-msg__text">
                    Hi! Write a journal entry above and I'll give you
                    personalised advice based on your mood. 😊
                </p>
            </div>
            {% endif %}
        </div>
 
        <!-- Chat input row -->
        <div style="display:flex;gap:8px;">
            <input
                type="text"
                id="coach-input"
                placeholder="Ask your coach anything…"
                style="flex:1;padding:10px 14px;border:1px solid #ccc;
                       border-radius:6px;font-size:15px;"
                onkeydown="if(event.key==='Enter'){sendCoachMessage();}"
            />
            <button type="button" onclick="sendCoachMessage()">Send</button>
        </div>
 
        <p id="coach-typing"
           style="display:none;font-size:13px;color:#888;margin-top:6px;">
            Coach is typing…
        </p>
    </div>
    <!-- ════════════════════════════════════════════════════════════════
         END COACH PANEL
    ═══════════════════════════════════════════════════════════════════ -->
 
    <div class="history-card">
        <h2>Your Journal History</h2>
        {% if entries %}
        <ul class="entry-list">
            {% for e in entries %}
            <li>
                <div class="entry-text">{{ e.text }}</div>
                <div class="entry-mood">Mood: <strong>{{ e.mood }}</strong></div>
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <p>No journal entries yet.</p>
        {% endif %}
    </div>
 
    <div class="dashboard-actions">
        <a href="{{ url_for('history') }}">View History</a> |
        <a href="{{ url_for('score') }}">Mood Score</a>
    </div>
 
</div>
 
<!-- ══════════════════════════════════════════════════════════════════════
     INLINE STYLES  — only for the two new panels; nothing existing changed
════════════════════════════════════════════════════════════════════════ -->
<style>
/* Coach message bubbles */
.coach-msg {
    display: flex;
    flex-direction: column;
    max-width: 82%;
}
.coach-msg--coach {
    align-self: flex-start;
}
.coach-msg--user {
    align-self: flex-end;
    align-items: flex-end;
}
.coach-msg__label {
    font-size: 11px;
    font-weight: 600;
    color: #888;
    margin-bottom: 3px;
    text-transform: uppercase;
    letter-spacing: .04em;
}
.coach-msg__text {
    margin: 0;
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 14px;
    line-height: 1.55;
    white-space: pre-line;
}
.coach-msg--coach .coach-msg__text {
    background: #e8f4fd;
    color: #1a1a2e;
    border-bottom-left-radius: 3px;
}
.coach-msg--user .coach-msg__text {
    background: #1a1a2e;
    color: #fff;
    border-bottom-right-radius: 3px;
}
 
/* Mood history pills in trend panel */
.mood-pill {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    background: #e8f4fd;
    color: #1a1a2e;
    border: 1px solid #b3d8f0;
}
.mood-pill--current {
    background: #1a1a2e;
    color: #fff;
    border-color: #1a1a2e;
}
</style>
 
<!-- ══════════════════════════════════════════════════════════════════════
     JAVASCRIPT  — mood trend + coach logic; no existing JS affected
════════════════════════════════════════════════════════════════════════ -->
<script>
/* ── Shared state ─────────────────────────────────────────────────── */
// Conversation history kept in memory (browser-side only, no DB needed)
const coachHistory = [];
 
/* ── Helpers ──────────────────────────────────────────────────────── */
function scrollCoachToBottom() {
    const box = document.getElementById("coach-messages");
    if (box) box.scrollTop = box.scrollHeight;
}
 
function appendCoachMessage(role, text) {
    const box = document.getElementById("coach-messages");
    const wrap = document.createElement("div");
    wrap.className = "coach-msg coach-msg--" + role;
 
    const label = document.createElement("span");
    label.className = "coach-msg__label";
    label.textContent = role === "coach" ? "Coach" : "You";
 
    const bubble = document.createElement("p");
    bubble.className = "coach-msg__text";
    bubble.textContent = text;
 
    wrap.appendChild(label);
    wrap.appendChild(bubble);
    box.appendChild(wrap);
    scrollCoachToBottom();
}
 
/* ── Mood Trend ───────────────────────────────────────────────────── */
function loadMoodTrend() {
    document.getElementById("trend-loading").style.display = "block";
    document.getElementById("trend-content").style.display  = "none";
    document.getElementById("trend-error").style.display    = "none";
 
    fetch("/mood_compare?limit=5")
        .then(function(r) { return r.json(); })
        .then(function(data) {
            document.getElementById("trend-loading").style.display = "none";
 
            if (data.error) {
                document.getElementById("trend-error").style.display = "block";
                return;
            }
 
            // Summary sentence
            document.getElementById("trend-summary").textContent =
                data.comparison_summary || "";
 
            // Mini mood history pills (newest = current, highlighted)
            var histDiv = document.getElementById("trend-history");
            histDiv.innerHTML = "";
            if (data.mood_history && data.mood_history.length) {
                data.mood_history.forEach(function(item, idx) {
                    var pill = document.createElement("span");
                    pill.className = "mood-pill" + (idx === 0 ? " mood-pill--current" : "");
                    pill.textContent = (idx === 0 ? "▶ " : "") + item.mood;
                    histDiv.appendChild(pill);
                });
            }
 
            // AI suggestions
            document.getElementById("trend-suggestions").textContent =
                data.ai_suggestions || "";
 
            document.getElementById("trend-content").style.display = "block";
        })
        .catch(function() {
            document.getElementById("trend-loading").style.display = "none";
            document.getElementById("trend-error").style.display   = "block";
        });
}
 
/* ── Proactive Coach Message ──────────────────────────────────────── */
function loadProactiveCoach(mood) {
    fetch("/coach/proactive?mood=" + encodeURIComponent(mood))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var el = document.getElementById("proactive-msg-text");
            if (el && data.coach_message) {
                el.textContent = data.coach_message;
                // Seed conversation history so follow-up chat has context
                coachHistory.push({ role: "coach", text: data.coach_message });
            }
        })
        .catch(function() {
            var el = document.getElementById("proactive-msg-text");
            if (el) {
                el.textContent =
                    "Hi! I'm here to help. Feel free to share how you're doing.";
            }
        });
}
 
/* ── Chat with Coach ──────────────────────────────────────────────── */
function sendCoachMessage() {
    var input = document.getElementById("coach-input");
    var msg   = (input.value || "").trim();
    if (!msg) return;
 
    // Render user bubble immediately
    appendCoachMessage("user", msg);
    coachHistory.push({ role: "user", text: msg });
    input.value = "";
 
    // Show typing indicator
    document.getElementById("coach-typing").style.display = "block";
    scrollCoachToBottom();
 
    fetch("/coach/message", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ message: msg, history: coachHistory })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        document.getElementById("coach-typing").style.display = "none";
        var reply = data.reply || "I'm here with you. Tell me more.";
        appendCoachMessage("coach", reply);
        coachHistory.push({ role: "coach", text: reply });
    })
    .catch(function() {
        document.getElementById("coach-typing").style.display = "none";
        appendCoachMessage("coach",
            "Sorry, I couldn't reach the server. Please try again.");
    });
}
 
/* ── On page load ─────────────────────────────────────────────────── */
document.addEventListener("DOMContentLoaded", function() {
    // Always load the mood trend panel
    loadMoodTrend();
 
    // If a new entry was just submitted, fetch the proactive coach message
    {% if latest_mood %}
    loadProactiveCoach("{{ latest_mood | e }}");
    {% endif %}
 
    scrollCoachToBottom();
});
</script>
 
{% endblock %}
 




