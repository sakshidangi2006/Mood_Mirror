js
const history = [];  // keep this in memory across turns

async function sendToCoach(userText) {
  history.push({ role: "user", text: userText });
  const res = await fetch("/coach/message", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ message: userText, history })
  });
  const data = await res.json();
  history.push({ role: "coach", text: data.reply });
  // render data.reply in your chat UI
}
No new DB columns, no new dependencies — both routes reuse your existing generate_recommendations() from ai.py with a richer prompt context.


