<script>
function loadMoodCompare() {
  fetch("/mood_compare?limit=5")
    .then(r => r.json())
    .then(data => {
      document.getElementById("mood-compare-result").innerHTML = `
        <p><strong>Trend:</strong> ${data.trend}</p>
        <p>${data.comparison_summary}</p>
        <p><strong>AI Suggestions:</strong> ${data.ai_suggestions}</p>
      `;
    });
}
